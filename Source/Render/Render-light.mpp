export module be.render:light;

import be.core;

export namespace be {

struct DirectionalLight
{
    Vec3 direction{0.0f, -1.0f, 0.0f};
    Vec3 color{1.0f, 1.0f, 1.0f};
    float intensity = 1.0f;
};

struct PointLight
{
    Vec3 position{0.0f, 0.0f, 0.0f};
    Vec3 color{1.0f, 1.0f, 1.0f};
    float intensity = 1.0f;
    float range = 10.0f;
};

struct AmbientLight
{
    Vec3 color{0.2f, 0.2f, 0.3f};
    float intensity = 1.0f;
};

} // namespace be
